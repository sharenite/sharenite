#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
STAGING_ENV_FILE="${ROOT_DIR}/.envrc.staging"

if [[ ! -f "${STAGING_ENV_FILE}" ]]; then
  echo "Missing ${STAGING_ENV_FILE}"
  exit 1
fi

(
  set -a
  # shellcheck disable=SC1090
  source "${STAGING_ENV_FILE}"
  set +a
  cd "${ROOT_DIR}"
  bundle exec kamal "$@" -d staging
)
