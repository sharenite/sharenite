#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PRODUCTION_ENV_FILE="${ROOT_DIR}/.envrc.production"

if [[ ! -f "${PRODUCTION_ENV_FILE}" ]]; then
  echo "Missing ${PRODUCTION_ENV_FILE}"
  exit 1
fi

(
  set -a
  # shellcheck disable=SC1090
  source "${PRODUCTION_ENV_FILE}"
  set +a
  cd "${ROOT_DIR}"

  exec bundle exec kamal "$@"
)
