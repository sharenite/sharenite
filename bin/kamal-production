#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PRODUCTION_ENV_FILE="${ROOT_DIR}/.envrc.production"

if [[ ! -f "${PRODUCTION_ENV_FILE}" ]]; then
  echo "Missing ${PRODUCTION_ENV_FILE}"
  exit 1
fi

(
  set -a
  # shellcheck disable=SC1090
  source "${PRODUCTION_ENV_FILE}"
  set +a
  cd "${ROOT_DIR}"

  args=("$@")
  dest_args=(-d production)

  if [[ " ${args[*]} " == *" -- "* ]]; then
    final_args=()
    inserted=false
    for arg in "${args[@]}"; do
      if [[ "${arg}" == "--" && "${inserted}" == false ]]; then
        final_args+=("${dest_args[@]}")
        inserted=true
      fi
      final_args+=("${arg}")
    done
    exec bundle exec kamal "${final_args[@]}"
  else
    exec bundle exec kamal "${args[@]}" "${dest_args[@]}"
  fi
)
