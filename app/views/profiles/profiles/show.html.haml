- games_count = @profile_stats[:games_count]
- games_played_count = @profile_stats[:games_played_count]
- playlists_count = @profile_stats[:playlists_count]
- is_own_profile = user_signed_in? && @current_user_id == @profile.user_id
- active_friends_count = @profile_stats[:active_friends_count]
- profile_url_value = profile_url(@profile)

= render "profiles/profiles/profile_nav", current_section: :profile

.row.g-3.mb-3
  - if @can_view_games
    .col-12.col-md-6.col-xl-3
      .card.profiles-section-card.h-100
        .card-body
          .profiles-stat-label Games
          .profiles-stat-value= games_count
    .col-12.col-md-6.col-xl-3
      .card.profiles-section-card.h-100
        .card-body
          .profiles-stat-label Played Games
          .profiles-stat-value= games_played_count
          .small.text-muted.mt-1 Games with last activity
  - if @can_view_playlists || is_own_profile
    .col-12.col-md-6.col-xl-3
      .card.profiles-section-card.h-100
        .card-body
          .profiles-stat-label Playlists
          .profiles-stat-value= playlists_count
          .small.text-muted.mt-1 Visible under playlist privacy
  - if @can_view_friends || is_own_profile
    .col-12.col-md-6.col-xl-3
      .card.profiles-section-card.h-100
        .card-body
          .profiles-stat-label Friends
          .profiles-stat-value= active_friends_count

.card.profiles-section-card
  .card-body
    %h2.h5.mb-3 Profile URL
    %p.text-muted.small.mb-2 Share this link:
    .profiles-url-box.text-break= profile_url_value

- if @can_view_gaming_activity
  .row.g-3.mt-1
    .col-12.col-xl-7
      .card.profiles-section-card.h-100
        .card-body
          .d-flex.align-items-center.justify-content-between.gap-2.mb-2
            %h2.h5.mb-0 Recent game activity
            - if @can_view_games
              = link_to "Open games", profile_games_path(@profile), class: "profiles-action-pill profiles-action-pill-sm"
          - if @recent_games.any?
            .table-responsive.profiles-table-wrap
              %table.table.table-sm.align-middle.profiles-table.mb-0
                %thead
                  %tr
                    %th Name
                    %th Last activity
                    %th.text-end
                %tbody
                  - @recent_games.each do |game|
                    %tr
                      %td.fw-semibold= game.name
                      %td= time_ago_in_words(game.last_activity) + " ago"
                      %td.text-end
                        - if @can_view_games
                          = link_to "Show", profile_game_path(@profile, game), class: "profiles-action-pill profiles-action-pill-primary profiles-action-pill-sm"
          - else
            %p.text-muted.mb-0 No recent activity yet.

    .col-12.col-xl-5
      .card.profiles-section-card.h-100
        .card-body
          .d-flex.flex-wrap.align-items-center.justify-content-between.gap-2.mb-3
            %h2.h5.mb-0 Current game activity
            - if @can_view_games
              = link_to "Open games", profile_games_path(@profile), class: "profiles-action-pill profiles-action-pill-sm"
          - if @active_games.any?
            .d-flex.flex-column.gap-2
              - @active_games.each do |game|
                .d-flex.flex-wrap.align-items-center.justify-content-between.gap-2
                  .fw-semibold= game.name
                  .d-flex.flex-wrap.justify-content-end.gap-2
                    - game_activity_states(game).each do |state|
                      %span{class: profile_activity_pill_class(state[:tone])}= state[:label]
                    - if @can_view_games
                      = link_to "Show", profile_game_path(@profile, game), class: "profiles-action-pill profiles-action-pill-sm"
          - else
            %p.text-muted.mb-0 No active game runtime statuses right now.
