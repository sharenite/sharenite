- games_count = @profile.user.games.count
- playlists_count = @profile.user.playlists.count
- is_own_profile = user_signed_in? && current_user.profile == @profile
- active_friends_count = @profile.user.friends.count
- pending_received_count = is_own_profile ? current_user.pending_inviters.count : 0
- profile_url_value = profile_url(@profile)
- invite_tab = @friendship_state&.to_sym == :you_declined ? "friends" : "sent"
- invite_data = @friendship_state&.to_sym == :you_declined ? { turbo_frame: "_top", turbo_prefetch: false, turbo_confirm: "You previously declined this invitation. Add this user back to friends?" } : { turbo_frame: "_top", turbo_prefetch: false }

.profiles-show-header.card.profiles-section-card.mb-3
  .card-body
    .d-flex.flex-wrap.align-items-start.justify-content-between.gap-3
      .d-flex.align-items-start.gap-3.min-w-0
        .profiles-show-avatar
          %i.bi.bi-person-circle
        .min-w-0
          %h1.mb-1.text-break= @profile.name
          .d-flex.flex-wrap.gap-2
            %span.profiles-show-badge
              Privacy:
              %strong.ms-1= @profile.privacy.humanize
            - if @profile.vanity_url.present?
              %span.profiles-show-badge
                Vanity:
                %strong.ms-1= @profile.vanity_url
      .d-flex.flex-wrap.gap-2
        = link_to "Games", profile_games_path(@profile), class: "profiles-action-pill profiles-action-pill-primary"
        - if is_own_profile
          = link_to "Edit profile", edit_profile_path(@profile), class: "profiles-action-pill"
          = link_to "Friends", profile_friends_path(@profile, tab: "friends"), class: "profiles-action-pill"
          = link_to "Playlists", profile_playlists_path(@profile), class: "profiles-action-pill"
        - elsif user_signed_in?
          - if @friendship_state&.to_sym == :invite_received
            = link_to profile_friendship_state_label(@friendship_state), profile_friends_path(current_user.profile, tab: "received"), class: profile_friendship_state_class(@friendship_state)
          - elsif @friendship_state.present? && @friendship_state.to_sym != :you_declined
            %span{class: profile_friendship_state_class(@friendship_state)}= profile_friendship_state_label(@friendship_state)
          - else
            = link_to "Invite", profile_invite_friend_path(@profile, tab: invite_tab), class: "profiles-action-pill", data: invite_data
        = link_to "Back", profiles_path, class: "profiles-action-pill"

.row.g-3.mb-3
  .col-12.col-md-6.col-xl-3
    .card.profiles-section-card.h-100
      .card-body
        .profiles-stat-label Games
        .profiles-stat-value= games_count
  .col-12.col-md-6.col-xl-3
    .card.profiles-section-card.h-100
      .card-body
        .profiles-stat-label Playlists
        .profiles-stat-value= playlists_count
  .col-12.col-md-6.col-xl-3
    .card.profiles-section-card.h-100
      .card-body
        .profiles-stat-label Friends
        .profiles-stat-value= active_friends_count
  .col-12.col-md-6.col-xl-3
    .card.profiles-section-card.h-100
      .card-body
        .profiles-stat-label Pending invites
        .profiles-stat-value= pending_received_count

.row.g-3
  .col-12.col-lg-7
    .card.profiles-section-card.h-100
      .card-body
        %h2.h5.mb-3 Profile details
        %dl.row.mb-0
          %dt.col-5.col-md-4.text-muted Name
          %dd.col-7.col-md-8= @profile.name

          %dt.col-5.col-md-4.text-muted Vanity URL
          %dd.col-7.col-md-8= @profile.vanity_url.presence || "N/A"

          %dt.col-5.col-md-4.text-muted Privacy
          %dd.col-7.col-md-8= @profile.privacy.humanize

          %dt.col-5.col-md-4.text-muted Member since
          %dd.col-7.col-md-8= time_ago_in_words(@profile.created_at) + " ago"

  .col-12.col-lg-5
    .card.profiles-section-card.h-100
      .card-body
        %h2.h5.mb-3 Profile URL
        %p.text-muted.small.mb-2 Share this link:
        .profiles-url-box.text-break= profile_url_value
        .small.text-muted.mt-2 Works for public and friendly profiles.
