= form_with(url: profile_games_path(@profile), method: :get, class: "games-search-form", data: { controller: "search-form", turbo_frame: "games", turbo_action: "replace" }) do |form|
  - current_sort = params[:sort].presence || (@can_view_gaming_activity ? "last_activity_desc" : "name_asc")
  .row.g-1
    .col-12
      = form.label :search_query, "Search", class: "form-label mb-1 small text-muted"
      = form.text_field :search_query, value: params[:search_query], class: "form-control", placeholder: "Title...", data: { action: "input->search-form#search" }
    .col-12.d-flex.d-lg-none.justify-content-between.gap-2.games-search-mobile-actions
      %button.btn.btn-outline-secondary.games-search-mobile-toggle{
        type: "button",
        data: { bs_toggle: "collapse", bs_target: "#games-search-advanced", search_form_target: "mobileToggle" },
        aria: { expanded: "false", controls: "games-search-advanced" }
      }
        Filters
      .d-inline-flex.gap-2
        = link_to "Reset", profile_games_path(@profile), class: "btn btn-outline-secondary games-search-reset", data: { turbo: false, action: "click->search-form#rememberResetState" }
        = form.submit "Apply", class: "btn btn-primary games-search-apply"

    .col-12.collapse.d-lg-block#games-search-advanced{
      data: { search_form_target: "advancedFilters", action: "shown.bs.collapse->search-form#rememberOpen hidden.bs.collapse->search-form#rememberClosed" }
    }
      .row.g-1
        .col-12.d-lg-none
          = form.label :sort, "Sort", class: "form-label mb-1 small text-muted"
          = form.select :sort, options_for_select(games_sort_options, current_sort), {}, class: "form-select", data: { action: "change->search-form#search" }
        .col-12.col-md-6.col-xl-4
          = form.label :source_ids, "Source", class: "form-label mb-1 small text-muted"
          = form.select :source_ids, options_for_select([["No source", Profiles::GamesController::NONE_FILTER_VALUE]] + @source_options.to_a, Array(params[:source_ids])), {}, multiple: true, class: "form-select", data: { controller: "choice", action: "change->search-form#search" }
        .col-12.col-md-6.col-xl-4
          = form.label :completion_status_ids, "Status", class: "form-label mb-1 small text-muted"
          = form.select :completion_status_ids, options_for_select([["No status", Profiles::GamesController::NONE_FILTER_VALUE]] + @completion_status_options.to_a, Array(params[:completion_status_ids])), {}, multiple: true, class: "form-select", data: { controller: "choice", action: "change->search-form#search" }
        .col-12.col-md-6.col-xl-4
          = form.label :platform_ids, "Platform", class: "form-label mb-1 small text-muted"
          = form.select :platform_ids, options_for_select([["No platform", Profiles::GamesController::NONE_FILTER_VALUE]] + @platform_options.to_a, Array(params[:platform_ids])), {}, multiple: true, class: "form-select", data: { controller: "choice", action: "change->search-form#search" }
        .col-12.col-xl-6
          = form.label :tag_ids, "Tags", class: "form-label mb-1 small text-muted"
          = form.select :tag_ids, options_for_select([["No tags", Profiles::GamesController::NONE_FILTER_VALUE]] + @tag_options.to_a, Array(params[:tag_ids])), {}, multiple: true, class: "form-select", data: { controller: "choice", action: "change->search-form#search" }
        .col-12.col-xl-6
          = form.label :category_ids, "Categories", class: "form-label mb-1 small text-muted"
          = form.select :category_ids, options_for_select([["No category", Profiles::GamesController::NONE_FILTER_VALUE]] + @category_options.to_a, Array(params[:category_ids])), {}, multiple: true, class: "form-select", data: { controller: "choice", action: "change->search-form#search" }
        .col-12.col-lg-4
          = form.label :last_activity_from, "Last played from", class: "form-label mb-1 small text-muted"
          = form.date_field :last_activity_from, value: params[:last_activity_from], class: "form-control", data: { action: "change->search-form#search" }
        .col-12.col-lg-4
          = form.label :last_activity_to, "Last played to", class: "form-label mb-1 small text-muted"
          = form.date_field :last_activity_to, value: params[:last_activity_to], class: "form-control", data: { action: "change->search-form#search" }
        .col-12.col-lg-4
          = form.label :activity_state, "Activity", class: "form-label mb-1 small text-muted"
          = form.select :activity_state, options_for_select([["All", ""], ["Played", "played"], ["Unplayed", "unplayed"]], params[:activity_state]), {}, class: "form-select", data: { action: "change->search-form#search" }
        .col-12.d-flex.align-items-end
          .games-search-options.d-flex.flex-wrap.align-items-center.gap-3.w-100
            .form-check.m-0.d-flex.align-items-center.gap-2
              = form.check_box :favorite, { class: "form-check-input", checked: params[:favorite] == "1", data: { action: "change->search-form#search" } }, "1", "0"
              = form.label :favorite, "Favorites", class: "form-check-label"
            .form-check.m-0.d-flex.align-items-center.gap-2
              = form.check_box :installed, { class: "form-check-input", checked: params[:installed] == "1", data: { action: "change->search-form#search" } }, "1", "0"
              = form.label :installed, "Installed", class: "form-check-label"
            .form-check.m-0.d-flex.align-items-center.gap-2
              = form.check_box :notes_or_review, { class: "form-check-input", checked: params[:notes_or_review] == "1", data: { action: "change->search-form#search" } }, "1", "0"
              = form.label :notes_or_review, "Notes/Review", class: "form-check-label"
            .ms-auto.d-none.d-lg-inline-flex.gap-2
              = link_to "Reset", profile_games_path(@profile), class: "btn btn-outline-secondary games-search-reset", data: { turbo: false, action: "click->search-form#rememberResetState" }
              = form.submit "Apply filters", class: "btn btn-primary games-search-apply"
