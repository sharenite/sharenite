- playtime_seconds = game.playtime.to_i
- playtime_label = playtime_seconds.positive? ? distance_of_time_in_words(0, playtime_seconds) : "N/A"
- last_activity_label = game.last_activity ? "#{time_ago_in_words(game.last_activity)} ago" : "Never"
- added_label = game.added ? "#{time_ago_in_words(game.added)} ago" : "Never"
- modified_label = game.modified ? "#{time_ago_in_words(game.modified)} ago" : "Never"
- updated_label = "#{time_ago_in_words(game.updated_at)} ago"
- platforms_label = game.platforms.map(&:name).join(", ")
- tags_label = game.tags.map(&:name).join(", ")
- categories_label = game.categories.map(&:name).join(", ")
- genres_label = game.genres.map(&:name).join(", ")
- publishers_label = game.publishers.map(&:name).join(", ")
- regions_label = game.regions.map(&:name).join(", ")
- series_label = game.series.map(&:name).join(", ")
- igdb_id = game.igdb_cache&.igdb_id
- igdb_url = igdb_id.present? ? "https://www.igdb.com/games/#{igdb_id}" : nil
- install_size_label = game.install_size.present? ? number_to_human_size(game.install_size) : "N/A"
- last_size_scan_label = game.last_size_scan_date ? "#{time_ago_in_words(game.last_size_scan_date)} ago" : "N/A"
- recent_activity_label = game.recent_activity ? "#{time_ago_in_words(game.recent_activity)} ago" : "N/A"
- own_profile = @profile == current_user&.profile
- can_view_gaming_activity = @profile.gaming_activity_visible_to?(current_user)

.game-details
  .game-details__header.mb-3
    .d-flex.flex-wrap.align-items-center.gap-2.gap-md-3
      %h1.game-details__title.mb-0
        - if game.playnite_id && game.is_installed && own_profile
          = link_to "playnite://playnite/start/#{game.playnite_id}", class: "game-details__play", title: "Play" do
            %i.bi.bi-play-fill
        = game.name
      - if game.favorite
        %span.games-state-pill.games-state-pill--favorite Favorite
      - if own_profile && game.private_override?
        %span.games-state-pill.games-state-pill--private Private
      - if game.is_installed
        %span.games-state-pill.games-state-pill--installed Installed
      - if can_view_gaming_activity
        - game_activity_states(game).each do |state|
          %span{class: game_activity_pill_class(state[:tone])}= state[:label]

  .card.game-details__hero.mb-3
    .row.g-0
      .col-12.col-lg-4
        .game-details__cover-wrap
          %img.game-details__cover-img{alt: "#{game.name} cover", src: "https://picsum.photos/seed/#{game.id}/720/480"}/
      .col-12.col-lg-8
        .card-body.p-3.p-lg-4
          .d-flex.flex-wrap.gap-2.mb-3
            %span.game-details__meta-badge.games-meta-pill.games-meta-pill--wrap
              %span.games-meta-pill__label.games-meta-pill__label--source Source
              %span.games-meta-pill__value= game.source&.name || "No source"
            %span.game-details__meta-badge.games-meta-pill.games-meta-pill--wrap
              %span.games-meta-pill__label.games-meta-pill__label--status Status
              %span.games-meta-pill__value= game.completion_status&.name || "No status"
            %span.game-details__meta-badge.games-meta-pill.games-meta-pill--wrap
              %span.games-meta-pill__label.games-meta-pill__label--category Categories
              %span.games-meta-pill__value= categories_label.presence || "N/A"
            %span.game-details__meta-badge.games-meta-pill.games-meta-pill--wrap
              %span.games-meta-pill__label.games-meta-pill__label--platform Platforms
              %span.games-meta-pill__value= platforms_label.presence || "N/A"
            %span.game-details__meta-badge.games-meta-pill.games-meta-pill--wrap
              %span.games-meta-pill__label.games-meta-pill__label--tag Tags
              %span.games-meta-pill__value= tags_label.presence || "N/A"

          .row.g-2.g-md-3.mb-3.game-details__stats-row
            - if can_view_gaming_activity
              .col-6.col-md-3
                .game-details__stat
                  .game-details__stat-label Last activity
                  .game-details__stat-value= last_activity_label
              .col-6.col-md-3
                .game-details__stat
                  .game-details__stat-label Playtime
                  .game-details__stat-value= playtime_label
            .col-6.col-md-3
              .game-details__stat
                .game-details__stat-label Play count
                .game-details__stat-value= game.play_count.to_i
            .col-6.col-md-3
              .game-details__stat
                .game-details__stat-label Last updated
                .game-details__stat-value= updated_label

          - if game.description.present?
            .game-details__description
              = sanitize(game.description)

  .row.g-3
    .col-12.col-xl-6
      .card.h-100
        .card-body
          %h5.card-title.mb-3 Library
          %dl.game-details__list
            %dt Added
            %dd= added_label
            %dt Modified
            %dd= modified_label
            %dt Release date
            %dd= game.release_date || "N/A"
            %dt Categories
            %dd= categories_label.presence || "N/A"
            %dt Version
            %dd= game.version.presence || "N/A"
            %dt Install size
            %dd= install_size_label
            %dt Last size scan
            %dd= last_size_scan_label

    .col-12.col-xl-6
      .card.h-100
        .card-body
          %h5.card-title.mb-3 Scores & Notes
          %dl.game-details__list
            %dt User score
            %dd= game.user_score || "N/A"
            %dt Community score
            %dd= game.community_score || "N/A"
            %dt Critic score
            %dd= game.critic_score || "N/A"
            %dt Notes
            %dd= game.notes.to_s.strip.presence || "No notes"

  .row.g-3.mt-1
    .col-12.col-xl-6
      .card.h-100
        .card-body
          %h5.card-title.mb-3 Runtime
          %dl.game-details__list
            %dt Custom game
            %dd= game.is_custom_game ? "Yes" : "No"
            %dt Installed
            %dd= game.is_installed ? "Yes" : "No"
            - if can_view_gaming_activity
              %dt Activity status
              %dd
                .d-flex.flex-wrap.gap-2
                  - if game_activity_states(game).any?
                    - game_activity_states(game).each do |state|
                      %span{class: game_activity_pill_class(state[:tone])}= state[:label]
                  - else
                    %span.text-muted None
            %dt Override install state
            %dd= game.override_install_state ? "Yes" : "No"
            %dt System HDR
            %dd= game.enable_system_hdr ? "Yes" : "No"
            - if can_view_gaming_activity
              %dt Recent activity
              %dd= recent_activity_label

    .col-12.col-xl-6
      .card.h-100
        .card-body
          %h5.card-title.mb-3 IGDB
          %dl.game-details__list
            %dt IGDB ID
            %dd= game.igdb_cache&.igdb_id || "N/A"
            %dt IGDB name
            %dd= game.igdb_cache&.name || "N/A"
            %dt IGDB URL
            %dd
              - if igdb_url
                = link_to "Open on IGDB", igdb_url, target: "_blank", rel: "noopener noreferrer"
              - else
                N/A

  .row.g-3.mt-1
    .col-12.col-xl-6
      .card.h-100
        .card-body
          %h5.card-title.mb-3 Metadata
          %dl.game-details__list
            %dt Genres
            %dd= genres_label.presence || "N/A"
            %dt Publishers
            %dd= publishers_label.presence || "N/A"
            %dt Regions
            %dd= regions_label.presence || "N/A"
            %dt Series
            %dd= series_label.presence || "N/A"

    .col-12.col-xl-6
      .card.h-100
        .card-body
          %h5.card-title.mb-3 Links & Files
          %dl.game-details__list
            %dt ROM entries
            %dd= game.roms.count
            %dt External links
            %dd
              - if game.links.any?
                %ul.game-details__links-list
                  - game.links.order(:name).each do |link|
                    %li
                      = link_to(link.name.presence || link.url, link.url, target: "_blank", rel: "noopener noreferrer")
              - else
                N/A

  - if own_profile
    .accordion.game-details__accordion.mt-3#gameTechnicalDetails
      .accordion-item
        %h2.accordion-header#gameTechnicalHeading
          %button.accordion-button.collapsed{type: "button", data: { bs_toggle: "collapse", bs_target: "#gameTechnicalCollapse" }, aria: { expanded: "false", controls: "gameTechnicalCollapse" }}
            Technical Details
        .accordion-collapse.collapse#gameTechnicalCollapse{aria: { labelledby: "gameTechnicalHeading" }, data: { bs_parent: "#gameTechnicalDetails" }}
          .accordion-body
            %dl.game-details__list
              %dt Game ID
              %dd= game.game_id || "N/A"
              %dt Playnite ID
              %dd= game.playnite_id || "N/A"
              %dt Plugin ID
              %dd= game.plugin_id || "N/A"
              %dt Sorting name
              %dd= game.sorting_name || "N/A"
              %dt Hidden
              %dd= game.hidden ? "Yes" : "No"
              %dt Private override
              %dd= game.private_override ? "Yes" : "No"
              %dt Include library plugin action
              %dd= game.include_library_plugin_action ? "Yes" : "No"
              %dt Install directory
              %dd= game.install_directory || "N/A"
              %dt Manual
              %dd= game.manual || "N/A"
              %dt Game started script
              %dd= game.game_started_script || "N/A"
              %dt Pre script
              %dd= game.pre_script || "N/A"
              %dt Post script
              %dd= game.post_script || "N/A"
              %dt Use global game started script
              %dd= game.use_global_game_started_script ? "Yes" : "No"
              %dt Use global pre script
              %dd= game.use_global_pre_script ? "Yes" : "No"
              %dt Use global post script
              %dd= game.use_global_post_script ? "Yes" : "No"
