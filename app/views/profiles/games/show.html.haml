- if notice.present?
  .alert.alert-success= notice
= render "profiles/profiles/profile_nav", current_section: :games
= render 'game_details', game: @game
.game-show-actions.d-flex.flex-wrap.gap-2.mt-3
  - if current_user == @profile.user
    = link_to "Edit", edit_profile_game_path(@profile, @game), class: "games-action-pill games-action-pill-primary"
  = link_to "Back to games", profile_games_path(@profile), class: "games-action-pill"
