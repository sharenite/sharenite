= render "profiles/profiles/profile_nav", current_section: :friends

.profiles-search-form.mb-3
  = form_with url: profile_friends_path(@profile), method: :get, local: true, data: { controller: "search-form", turbo_frame: "friends_list", turbo_action: "replace" } do |form|
    - if params[:sort].present?
      = hidden_field_tag :sort, params[:sort]
    .row.g-2
      .col-12
        = form.label :search_name, "Search name", class: "form-label mb-1 small text-muted"
        = form.text_field :search_name, value: params[:search_name], class: "form-control", placeholder: "Friend name...", data: { action: "input->search-form#search" }
      .col-12.d-flex.justify-content-end.gap-2
        = link_to "Reset", profile_friends_path(@profile), class: "btn btn-outline-secondary"
        = form.submit "Apply", class: "btn btn-primary"

= turbo_frame_tag "friends_list" do
  - filter_params = request.query_parameters.slice("search_name", "sort")
  - current_sort = params[:sort].presence || "last_active_desc"
  - tab_path = ->(tab_name) { profile_friends_path(@profile, filter_params.merge(tab: tab_name)) }
  .card.profiles-section-card.mt-3
    .card-body
      - if @own_profile
        %ul.nav.nav-tabs.profiles-friends-tabs.mb-3{role: "tablist"}
          %li.nav-item{role: "presentation"}
            = link_to tab_path.call("friends"), class: "nav-link #{'active' if @active_tab == 'friends'}", role: "tab", aria: { selected: (@active_tab == "friends").to_s }, data: { turbo_action: "advance" } do
              Friends
              %span.badge.rounded-pill.text-bg-secondary.ms-1= @friends_total_count
          %li.nav-item{role: "presentation"}
            = link_to tab_path.call("received"), class: "nav-link #{'active' if @active_tab == 'received'}", role: "tab", aria: { selected: (@active_tab == "received").to_s }, data: { turbo_action: "advance" } do
              Received
              %span.badge.rounded-pill.text-bg-secondary.ms-1= @invitations_received_count
          %li.nav-item{role: "presentation"}
            = link_to tab_path.call("sent"), class: "nav-link #{'active' if @active_tab == 'sent'}", role: "tab", aria: { selected: (@active_tab == "sent").to_s }, data: { turbo_action: "advance" } do
              Sent
              %span.badge.rounded-pill.text-bg-secondary.ms-1= @invitations_sent_count
          %li.nav-item{role: "presentation"}
            = link_to tab_path.call("declined"), class: "nav-link #{'active' if @active_tab == 'declined'}", role: "tab", aria: { selected: (@active_tab == "declined").to_s }, data: { turbo_action: "advance" } do
              Declined
              %span.badge.rounded-pill.text-bg-secondary.ms-1= @invitations_declined_count
          %li.nav-item{role: "presentation"}
            = link_to tab_path.call("blocked"), class: "nav-link #{'active' if @active_tab == 'blocked'}", role: "tab", aria: { selected: (@active_tab == "blocked").to_s }, data: { turbo_action: "advance" } do
              Blocked
              %span.badge.rounded-pill.text-bg-secondary.ms-1= @blocked_count
      - if @active_tab == "friends"
        .tab-content
          .tab-pane.fade.show.active{role: "tabpanel"}
            .profiles-search-form.d-md-none.mb-3
              = form_with url: profile_friends_path(@profile), method: :get, local: true, data: { controller: "search-form", turbo_frame: "friends_list", turbo_action: "replace" } do |form|
                = hidden_field_tag :tab, "friends"
                = hidden_field_tag :search_name, params[:search_name]
                .row.g-2
                  .col-12
                    = form.label :sort, "Sort by", class: "form-label mb-1 small text-muted"
                    = form.select :sort, options_for_select(friends_sort_options("friends"), current_sort), {}, { class: "form-select", data: { action: "change->search-form#search" } }

            - if @friends.total_pages > 1
              .d-flex.align-items-center.justify-content-end.mb-2
                = paginate @friends, theme: 'bootstrap-5', pagination_class: "flex-wrap justify-content-center"

            %p.profiles-section-summary Total friends listed: #{@friends_total_count}

            .profiles-list-desktop.d-none.d-md-block
              .table-responsive.profiles-table-wrap
                %table.table.table-sm.table-hover.align-middle.profiles-table.mb-0
                  %thead
                    %tr
                      %th= friends_sort_link(@profile, "Name", current_sort, { asc: "name_asc", desc: "name_desc" })
                      %th= friends_sort_link(@profile, "Games", current_sort, { asc: "games_asc", desc: "games_desc" })
                      %th= friends_sort_link(@profile, "Last active", current_sort, { asc: "last_active_asc", desc: "last_active_desc" })
                      %th= friends_sort_link(@profile, "Friends since", current_sort, { asc: "friends_since_asc", desc: "friends_since_desc" })
                      %th.text-end Actions
                  %tbody
                    - if @friends.any?
                      - @friends.each do |friend|
                        - games_count = (@friend_games_count_by_user_id || {}).fetch(friend.user_id, 0)
                        - can_view_games = @friend_game_library_visibility_by_user_id.fetch(friend.user_id, false)
                        - can_view_gaming_activity = @friend_gaming_activity_visibility_by_user_id.fetch(friend.user_id, false)
                        - last_active_label = profile_last_active_label(friend, current_user, can_view_gaming_activity:, last_active_at: (@friend_last_active_at_by_user_id || {})[friend.user_id])
                        - relation = @friend_relations_by_user_id[friend.user_id]
                        - friends_since_label = relation.present? ? profile_relation_time_label(relation.updated_at) : nil
                        %tr
                          %td.fw-semibold= friend.name
                          %td
                            - if can_view_games
                              = games_count
                            - else
                              %span.profiles-info-pill.profiles-info-pill-muted Hidden
                          %td
                            - if %w[Hidden Never].include?(last_active_label)
                              %span.profiles-info-pill.profiles-info-pill-muted= last_active_label
                            - else
                              = last_active_label
                          %td= friends_since_label
                          %td.text-end
                            .d-inline-flex.gap-1.flex-wrap.justify-content-end
                              - if can_view_games
                                = link_to "Games", profile_games_path(friend), class: "profiles-action-pill profiles-action-pill-sm", data: { turbo_frame: "_top" }
                              = link_to "Show", friend, class: "profiles-action-pill profiles-action-pill-sm profiles-action-pill-primary", data: { turbo_frame: "_top" }
                              - if relation.present?
                                = button_to "Unfriend", profile_unfriend_friend_path(@profile, id: relation.id, tab: "friends"), method: :delete, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Remove this friend?" }
                                = button_to "Block", profile_block_friend_path(@profile, id: relation.id, tab: "blocked"), method: :patch, class: "profiles-action-pill profiles-action-pill-danger profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Block this user? You and this user will become invisible to each other." }
                    - else
                      %tr
                        %td.text-muted{colspan: 5} No friends match current filters.

            .profiles-list-mobile.d-md-none
              .row.g-2
                - if @friends.any?
                  - @friends.each do |friend|
                    - games_count = (@friend_games_count_by_user_id || {}).fetch(friend.user_id, 0)
                    - can_view_games = @friend_game_library_visibility_by_user_id.fetch(friend.user_id, false)
                    - can_view_gaming_activity = @friend_gaming_activity_visibility_by_user_id.fetch(friend.user_id, false)
                    - last_active_label = profile_last_active_label(friend, current_user, can_view_gaming_activity:, last_active_at: (@friend_last_active_at_by_user_id || {})[friend.user_id])
                    - relation = @friend_relations_by_user_id[friend.user_id]
                    - friends_since_label = relation.present? ? profile_relation_time_label(relation.updated_at) : nil
                    .col-12
                      .card.profiles-mobile-card
                        .card-body.py-2.px-3
                          .profiles-friend-mobile-card
                            .profiles-friend-mobile-card__meta.min-w-0
                              .fw-semibold.text-break= friend.name
                              .small.text-muted
                                - if can_view_games
                                  = "Games: #{games_count}"
                                - else
                                  %span.profiles-info-pill.profiles-info-pill-sm.profiles-info-pill-muted Hidden
                              .small.text-muted
                                Last active:
                                - if %w[Hidden Never].include?(last_active_label)
                                  %span.profiles-info-pill.profiles-info-pill-sm.profiles-info-pill-muted.ms-1= last_active_label
                                - else
                                  %span.ms-1= last_active_label
                              - if friends_since_label.present?
                                .small.text-muted Friends since: #{friends_since_label}
                            .profiles-friend-mobile-card__actions
                              - if can_view_games
                                = link_to "Games", profile_games_path(friend), class: "profiles-action-pill profiles-action-pill-sm", data: { turbo_frame: "_top" }
                              = link_to "Show", friend, class: "profiles-action-pill profiles-action-pill-primary profiles-action-pill-sm", data: { turbo_frame: "_top" }
                              - if relation.present?
                                = button_to "Unfriend", profile_unfriend_friend_path(@profile, id: relation.id, tab: "friends"), method: :delete, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Remove this friend?" }
                                = button_to "Block", profile_block_friend_path(@profile, id: relation.id, tab: "blocked"), method: :patch, class: "profiles-action-pill profiles-action-pill-danger profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Block this user? You and this user will become invisible to each other." }
                - else
                  .col-12
                    .text-muted No friends match current filters.

            - if @friends.total_pages > 1
              .d-flex.align-items-center.justify-content-end.mt-3
                = paginate @friends, theme: 'bootstrap-5', pagination_class: "flex-wrap justify-content-center"
      - elsif @active_tab == "received"
        .tab-content
          .tab-pane.fade.show.active{role: "tabpanel"}
            .profiles-search-form.d-md-none.mb-3
              = form_with url: profile_friends_path(@profile), method: :get, local: true, data: { controller: "search-form", turbo_frame: "friends_list", turbo_action: "replace" } do |form|
                = hidden_field_tag :tab, "received"
                = hidden_field_tag :search_name, params[:search_name]
                .row.g-2
                  .col-12
                    = form.label :sort, "Sort by", class: "form-label mb-1 small text-muted"
                    = form.select :sort, options_for_select(friends_sort_options("received"), current_sort), {}, { class: "form-select", data: { action: "change->search-form#search" } }
            %p.profiles-section-summary Total received invitations listed: #{@invitations_received_count}
            - if @invitations_received.any?
              .profiles-list-desktop.d-none.d-md-block
                .table-responsive.profiles-table-wrap
                  %table.table.table-sm.align-middle.profiles-table.mb-0
                    %thead
                      %tr
                        %th= friends_sort_link(@profile, "Name", current_sort, { asc: "name_asc", desc: "name_desc" })
                        %th= friends_sort_link(@profile, "Received", current_sort, { asc: "sent_asc", desc: "sent_desc" })
                        %th.text-end Actions
                    %tbody
                      - @invitations_received.each do |invitation_received|
                        - sent_label = profile_relation_time_label(invitation_received.created_at)
                        %tr
                          %td.fw-semibold= public_profile_name(invitation_received.inviter)
                          %td= sent_label
                          %td.text-end
                            .d-inline-flex.gap-1.flex-wrap.justify-content-end
                              = link_to "Show", invitation_received.inviter.profile, class: "profiles-action-pill profiles-action-pill-sm profiles-action-pill-primary", data: { turbo_frame: "_top" }
                              = button_to "Accept", profile_accept_friend_path(@profile, id: invitation_received.id, tab: "friends"), method: :patch, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }
                              = button_to "Decline", profile_decline_friend_path(@profile, id: invitation_received.id, tab: "declined"), method: :patch, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }
                              = button_to "Block", profile_block_friend_path(@profile, id: invitation_received.id, tab: "blocked"), method: :patch, class: "profiles-action-pill profiles-action-pill-danger profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Block this user? You and this user will become invisible to each other." }
              .profiles-list-mobile.d-md-none
                .row.g-2
                  - @invitations_received.each do |invitation_received|
                    - sent_label = profile_relation_time_label(invitation_received.created_at)
                    .col-12
                      .card.profiles-mobile-card
                        .card-body.py-2.px-3
                          .profiles-friend-mobile-card
                            .profiles-friend-mobile-card__meta.min-w-0
                              .fw-semibold.text-break= public_profile_name(invitation_received.inviter)
                              .small.text-muted Received: #{sent_label}
                            .profiles-friend-mobile-card__actions
                              = link_to "Show", invitation_received.inviter.profile, class: "profiles-action-pill profiles-action-pill-sm profiles-action-pill-primary", data: { turbo_frame: "_top" }
                              = button_to "Accept", profile_accept_friend_path(@profile, id: invitation_received.id, tab: "friends"), method: :patch, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }
                              = button_to "Decline", profile_decline_friend_path(@profile, id: invitation_received.id, tab: "declined"), method: :patch, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }
                              = button_to "Block", profile_block_friend_path(@profile, id: invitation_received.id, tab: "blocked"), method: :patch, class: "profiles-action-pill profiles-action-pill-danger profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Block this user? You and this user will become invisible to each other." }
            - else
              %p.text-muted.mb-0 No invitations received.
      - elsif @active_tab == "sent"
        .tab-content
          .tab-pane.fade.show.active{role: "tabpanel"}
            .profiles-search-form.d-md-none.mb-3
              = form_with url: profile_friends_path(@profile), method: :get, local: true, data: { controller: "search-form", turbo_frame: "friends_list", turbo_action: "replace" } do |form|
                = hidden_field_tag :tab, "sent"
                = hidden_field_tag :search_name, params[:search_name]
                .row.g-2
                  .col-12
                    = form.label :sort, "Sort by", class: "form-label mb-1 small text-muted"
                    = form.select :sort, options_for_select(friends_sort_options("sent"), current_sort), {}, { class: "form-select", data: { action: "change->search-form#search" } }
            %p.profiles-section-summary Total sent invitations listed: #{@invitations_sent_count}
            - if @invitations_sent.any?
              .profiles-list-desktop.d-none.d-md-block
                .table-responsive.profiles-table-wrap
                  %table.table.table-sm.align-middle.profiles-table.mb-0
                    %thead
                      %tr
                        %th= friends_sort_link(@profile, "Name", current_sort, { asc: "name_asc", desc: "name_desc" })
                        %th= friends_sort_link(@profile, "Sent", current_sort, { asc: "sent_asc", desc: "sent_desc" })
                        %th.text-end Actions
                    %tbody
                      - @invitations_sent.each do |invitation_sent|
                        - sent_label = profile_relation_time_label(invitation_sent.created_at)
                        %tr
                          %td.fw-semibold= public_profile_name(invitation_sent.invitee)
                          %td= sent_label
                          %td.text-end
                            .d-inline-flex.gap-1.flex-wrap.justify-content-end
                              = link_to "Show", invitation_sent.invitee.profile, class: "profiles-action-pill profiles-action-pill-sm profiles-action-pill-primary", data: { turbo_frame: "_top" }
                              = button_to "Cancel", profile_cancel_friend_path(@profile, id: invitation_sent.id, tab: "sent"), method: :delete, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }
                              = button_to "Block", profile_block_friend_path(@profile, id: invitation_sent.id, tab: "blocked"), method: :patch, class: "profiles-action-pill profiles-action-pill-danger profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Block this user? You and this user will become invisible to each other." }
              .profiles-list-mobile.d-md-none
                .row.g-2
                  - @invitations_sent.each do |invitation_sent|
                    - sent_label = profile_relation_time_label(invitation_sent.created_at)
                    .col-12
                      .card.profiles-mobile-card
                        .card-body.py-2.px-3
                          .profiles-friend-mobile-card
                            .profiles-friend-mobile-card__meta.min-w-0
                              .fw-semibold.text-break= public_profile_name(invitation_sent.invitee)
                              .small.text-muted Sent: #{sent_label}
                            .profiles-friend-mobile-card__actions
                              = link_to "Show", invitation_sent.invitee.profile, class: "profiles-action-pill profiles-action-pill-sm profiles-action-pill-primary", data: { turbo_frame: "_top" }
                              = button_to "Cancel", profile_cancel_friend_path(@profile, id: invitation_sent.id, tab: "sent"), method: :delete, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }
                              = button_to "Block", profile_block_friend_path(@profile, id: invitation_sent.id, tab: "blocked"), method: :patch, class: "profiles-action-pill profiles-action-pill-danger profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Block this user? You and this user will become invisible to each other." }
            - else
              %p.text-muted.mb-0 No invitations sent.
      - else
        .tab-content
          .tab-pane.fade.show.active{role: "tabpanel"}
            .profiles-search-form.d-md-none.mb-3
              = form_with url: profile_friends_path(@profile), method: :get, local: true, data: { controller: "search-form", turbo_frame: "friends_list", turbo_action: "replace" } do |form|
                = hidden_field_tag :tab, @active_tab
                = hidden_field_tag :search_name, params[:search_name]
                .row.g-2
                  .col-12
                    = form.label :sort, "Sort by", class: "form-label mb-1 small text-muted"
                    = form.select :sort, options_for_select(friends_sort_options(@active_tab), current_sort), {}, { class: "form-select", data: { action: "change->search-form#search" } }
            - if @active_tab == "declined"
              %p.profiles-section-summary Total declined invitations listed: #{@invitations_declined_count}
            - else
              %p.profiles-section-summary Total blocked users listed: #{@blocked_count}
            - if @active_tab == "declined" && @invitations_declined.any?
              .profiles-list-desktop.d-none.d-md-block
                .table-responsive.profiles-table-wrap
                  %table.table.table-sm.align-middle.profiles-table.mb-0
                    %thead
                      %tr
                        %th= friends_sort_link(@profile, "Name", current_sort, { asc: "name_asc", desc: "name_desc" })
                        %th= friends_sort_link(@profile, "Status", current_sort, { asc: "status_asc", desc: "status_desc" })
                        %th= friends_sort_link(@profile, "Declined", current_sort, { asc: "declined_asc", desc: "declined_desc" })
                        %th.text-end Actions
                    %tbody
                      - @invitations_declined.each do |relation|
                        - other_user = relation.inviter_id == @profile.user.id ? relation.invitee : relation.inviter
                        - other_profile = other_user.profile
                        - you_declined = relation.invitee_id == @profile.user.id
                        - declined_label = profile_relation_time_label(relation.updated_at)
                        %tr
                          %td.fw-semibold= public_profile_name(other_user)
                          %td
                            - if you_declined
                              %span.profiles-info-pill.profiles-info-pill-sm.profiles-info-pill-muted You declined
                            - else
                              %span.profiles-info-pill.profiles-info-pill-sm.profiles-info-pill-muted Declined by them
                          %td= declined_label
                          %td.text-end
                            .d-inline-flex.gap-1.flex-wrap.justify-content-end
                              - if other_profile.present?
                                = link_to "Show", other_profile, class: "profiles-action-pill profiles-action-pill-sm profiles-action-pill-primary", data: { turbo_frame: "_top" }
                              - if you_declined && other_profile.present?
                                = button_to "Invite", profile_invite_friend_path(other_profile, tab: "friends"), method: :post, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "You previously declined this invitation. Add this user back to friends?" }
                              = button_to "Block", profile_block_friend_path(@profile, id: relation.id, tab: "blocked"), method: :patch, class: "profiles-action-pill profiles-action-pill-danger profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Block this user? You and this user will become invisible to each other." }
              .profiles-list-mobile.d-md-none
                .row.g-2
                  - @invitations_declined.each do |relation|
                    - other_user = relation.inviter_id == @profile.user.id ? relation.invitee : relation.inviter
                    - other_profile = other_user.profile
                    - you_declined = relation.invitee_id == @profile.user.id
                    - declined_label = profile_relation_time_label(relation.updated_at)
                    .col-12
                      .card.profiles-mobile-card
                        .card-body.py-2.px-3
                          .profiles-friend-mobile-card
                            .profiles-friend-mobile-card__meta.min-w-0
                              .fw-semibold.text-break= public_profile_name(other_user)
                              .small.text-muted
                                Status:
                                - if you_declined
                                  %span.profiles-info-pill.profiles-info-pill-sm.profiles-info-pill-muted.ms-1 You declined
                                - else
                                  %span.profiles-info-pill.profiles-info-pill-sm.profiles-info-pill-muted.ms-1 Declined by them
                              .small.text-muted Declined: #{declined_label}
                            .profiles-friend-mobile-card__actions
                              - if other_profile.present?
                                = link_to "Show", other_profile, class: "profiles-action-pill profiles-action-pill-sm profiles-action-pill-primary", data: { turbo_frame: "_top" }
                              - if you_declined && other_profile.present?
                                = button_to "Invite", profile_invite_friend_path(other_profile, tab: "friends"), method: :post, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "You previously declined this invitation. Add this user back to friends?" }
                              = button_to "Block", profile_block_friend_path(@profile, id: relation.id, tab: "blocked"), method: :patch, class: "profiles-action-pill profiles-action-pill-danger profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Block this user? You and this user will become invisible to each other." }
            - elsif @active_tab == "blocked" && @blocked_relations.any?
              .profiles-list-desktop.d-none.d-md-block
                .table-responsive.profiles-table-wrap
                  %table.table.table-sm.align-middle.profiles-table.mb-0
                    %thead
                      %tr
                        %th= friends_sort_link(@profile, "Name", current_sort, { asc: "name_asc", desc: "name_desc" })
                        %th= friends_sort_link(@profile, "Blocked since", current_sort, { asc: "blocked_asc", desc: "blocked_desc" })
                        %th.text-end Actions
                    %tbody
                      - @blocked_relations.each do |relation|
                        - blocked_profile = relation.invitee.profile
                        - blocked_since_label = profile_relation_time_label(relation.created_at)
                        %tr
                          %td.fw-semibold= public_profile_name(relation.invitee)
                          %td= blocked_since_label
                          %td.text-end
                            .d-inline-flex.gap-1.flex-wrap.justify-content-end
                              = button_to "Unblock", profile_unblock_friend_path(@profile, id: relation.id, tab: "blocked"), method: :delete, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Unblock this user?" }
              .profiles-list-mobile.d-md-none
                .row.g-2
                  - @blocked_relations.each do |relation|
                    - blocked_profile = relation.invitee.profile
                    - blocked_since_label = profile_relation_time_label(relation.created_at)
                    .col-12
                      .card.profiles-mobile-card
                        .card-body.py-2.px-3
                          .profiles-friend-mobile-card
                            .profiles-friend-mobile-card__meta.min-w-0
                              .fw-semibold.text-break= public_profile_name(relation.invitee)
                              .small.text-muted Blocked since: #{blocked_since_label}
                            .profiles-friend-mobile-card__actions
                              = button_to "Unblock", profile_unblock_friend_path(@profile, id: relation.id, tab: "blocked"), method: :delete, class: "profiles-action-pill profiles-action-pill-sm", form_class: "d-inline", form: { data: { turbo_frame: "_top" } }, data: { turbo_confirm: "Unblock this user?" }
            - else
              %p.text-muted.mb-0= @active_tab == "blocked" ? "No blocked users." : "No declined invitations."
